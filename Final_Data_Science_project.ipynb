# 10. Analyze the decade-wise MPG distribution
#=================================================================

def analyze_mpg_by_decade(df):
    model_year_col = "Model"
    mpg_col = "Real-World MPG"

    if model_year_col not in df.columns:
        print("\nSkipping decade analysis because 'Model' was not found.")
        return None

    if mpg_col not in df.columns:
        print("\nSkipping decade analysis because 'Real-World MPG' was not found.")
        return None

    decade_df = df.dropna(subset=[model_year_col, mpg_col]).copy()
    decade_df[model_year_col] = pd.to_numeric(decade_df[model_year_col], errors="coerce")
    decade_df = decade_df.dropna(subset=[model_year_col])

    decade_df["Decade_Num"] = (decade_df[model_year_col].astype(int) // 10) * 10
    decade_df["Decade"] = decade_df["Decade_Num"].astype(str) + "s"

    decade_order = (
        decade_df[["Decade", "Decade_Num"]]
        .drop_duplicates()
        .sort_values("Decade_Num")["Decade"]
        .tolist()
    )

    plt.figure(figsize=(12, 7))
    sns.set_style("whitegrid")

    sns.boxplot(
        data=decade_df,
        x="Decade",
        y=mpg_col,
        order=decade_order,
        palette="viridis"
    )

    medians = decade_df.groupby("Decade")[mpg_col].median()

    for i, decade in enumerate(decade_order):
        plt.text(
            i,
            medians.loc[decade],
            f"{medians.loc[decade]:.1f}",
            ha="center",
            va="center",
            fontsize=9,
            color="white",
            fontweight="bold"
        )

    plt.title("Distribution of Real-World MPG Across Decades", fontsize=15, fontweight="bold")
    plt.xlabel("Decade")
    plt.ylabel("Real-World MPG")
    plt.tight_layout()
    plt.savefig("mpg_spread_by_decade.png", dpi=300)
    plt.show()

    stats = decade_df.groupby("Decade")[mpg_col].describe().loc[decade_order]

    stats["IQR"] = (
        decade_df.groupby("Decade")[mpg_col].quantile(0.75)
        - decade_df.groupby("Decade")[mpg_col].quantile(0.25)
    )

    stats["Skewness"] = decade_df.groupby("Decade")[mpg_col].skew()

    print("\nMPG Statistics by Decade:")
    display(stats.round(3))

    return stats

# call function to analyze decade wide data
decade_stats = analyze_mpg_by_decade(df)

#=================================================================
# 11. Train final degree-3 polynomial model
#=================================================================

def train_final_model(X, y, numerical_features, categorical_features, degree=3):
    X_train, X_test, y_train, y_test = train_test_split(
        X,
        y,
        test_size=0.20,
        random_state=42
    )

    model = build_regression_pipeline(
        numerical_features,
        categorical_features,
        degree=degree,
        model_type="linear"
    )

    model.fit(X_train, y_train)
    y_pred = model.predict(X_test)

    mse = mean_squared_error(y_test, y_pred)
    mae = mean_absolute_error(y_test, y_pred)
    r2 = r2_score(y_test, y_pred)

    print(f"\nFinal Held-Out Test Results: Polynomial Degree {degree}")
    print(f"MSE: {mse:.3f}")
    print(f"MAE: {mae:.3f}")
    print(f"R²:  {r2:.3f}")

    return model, X_test, y_test, y_pred


final_model, X_test, y_test, y_pred = train_final_model(
    X,
    y,
    numerical_features,
    categorical_features,
    degree=3
)

