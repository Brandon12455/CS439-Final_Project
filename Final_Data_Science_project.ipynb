#=================================================================
# 3. Clean column names and auto-detect important columns
#=================================================================

def normalize_colname(col):
    return (
        str(col)
        .strip()
        .lower()
        .replace("-", " ")
        .replace("_", " ")
        .replace("/", " ")
        .replace("(", "")
        .replace(")", "")
    )


def find_column(df, possible_names):
    normalized_map = {normalize_colname(col): col for col in df.columns}

    for name in possible_names:
        normalized_name = normalize_colname(name)
        if normalized_name in normalized_map:
            return normalized_map[normalized_name]

    for col in df.columns:
        norm_col = normalize_colname(col)
        for name in possible_names:
            if normalize_colname(name) in norm_col:
                return col

    return None


def standardize_columns(df):
    df = df.copy()

    # Define the columns that can be converted into standardized names
    column_candidates = {
        "Model Year": [
            "Model Year", "model year", "ModelYear", "MY"
        ],
        "Real-World MPG": [
            "Real-World MPG", "Real World MPG", "Real-World Fuel Economy",
            "Real World Fuel Economy", "Adjusted MPG", "MPG", "Fuel Economy"
        ],
        "Engine Cylinders": [
            "Engine Cylinders", "Cylinders", "Cylinder", "Number of Cylinders"
        ],
        "Engine Displacement": [
            "Engine Displacement", "Displacement", "Engine Displacement Liters",
            "Engine Size", "Engine Size L"
        ],
        "Transmission Type": [
            "Transmission Type", "Transmission", "Trans", "Transmission Description"
        ],
        "Vehicle Type": [
            "Vehicle Type", "Vehicle Class", "Type"
        ],
        "Drive Type": [
            "Drive Type", "Drive", "Drivetrain"
        ],
        "Regulatory Class": [
            "Regulatory Class", "Reg Class", "EPA Class", "Class"
        ],
        "Make": [
            "Make", "Manufacturer", "Mfr Name", "Company"
        ],
        "Model": [
            "Model", "Carline", "Vehicle Model"
        ],
        "Fuel Type": [
            "Fuel Type", "Fuel", "Fuel Type 1"
        ]
    }

    rename_dict = {}

    for standard_name, candidates in column_candidates.items():
        found = find_column(df, candidates)
        if found is not None:
            rename_dict[found] = standard_name

    df = df.rename(columns=rename_dict)

    # Now list out all the cols was detected and renamed
    print("\nDetected/renamed columns:")
    for old, new in rename_dict.items():
        print(f"{old}  -->  {new}")

    return df


df = standardize_columns(raw_df)

