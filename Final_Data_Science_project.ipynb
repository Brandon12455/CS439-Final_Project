#=================================================================
# 4. Prepare EPA data from the list
#=================================================================

def load_epa_data(df):
    df = df.copy()

    target_col = "Real-World MPG"

    if target_col not in df.columns:
        raise ValueError(
            f"\nCould not find target column '{target_col}'.\n"
            f"Your columns are:\n{df.columns.tolist()}\n\n"
            "Fix: rename MPG column to 'Real-World MPG'."
        )

    # Convert target to numeric
    df[target_col] = pd.to_numeric(df[target_col], errors="coerce")

    # Drop rows with missing target
    df = df.dropna(subset=[target_col]).copy()

    # Convert numerical columns when present
    for col in ["Model Year", "Engine Cylinders", "Engine Displacement"]:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")

    # Binary feature: Truck/SUV indicator
    if "Vehicle Type" in df.columns:
        df["Is_Truck_SUV"] = df["Vehicle Type"].apply(
            lambda x: 1 if ("truck" in str(x).lower() or "suv" in str(x).lower()) else 0
        )
    elif "Regulatory Class" in df.columns:
        df["Is_Truck_SUV"] = df["Regulatory Class"].apply(
            lambda x: 1 if ("truck" in str(x).lower() or "suv" in str(x).lower()) else 0
        )
    else:
        df["Is_Truck_SUV"] = 0

    # Binary feature: Manual transmission indicator
    if "Transmission Type" in df.columns:
        df["Is_Manual"] = df["Transmission Type"].apply(
            lambda x: 1 if "manual" in str(x).lower() else 0
        )
    else:
        df["Is_Manual"] = 0

    numerical_features = [
        col for col in [
            "Model Year",
            "Engine Cylinders",
            "Engine Displacement",
            "Is_Truck_SUV",
            "Is_Manual"
        ]
        if col in df.columns
    ]

    categorical_features = [
        col for col in [
            "Vehicle Type",
            "Regulatory Class",
            "Transmission Type",
            "Drive Type",
            "Make",
            "Fuel Type"
        ]
        if col in df.columns
    ]

    feature_cols = numerical_features + categorical_features

    if len(feature_cols) == 0:
        raise ValueError("No usable feature columns were found.")

    X = df[feature_cols].copy()
    y = df[target_col].copy()

    print("\nRows used after cleaning of data:", len(df))
    print("Target column:", target_col)
    print("Numerical features:", numerical_features)
    print("Categorical features:", categorical_features)

    return df, X, y, numerical_features, categorical_features

# Loading EPA data...

df, X, y, numerical_features, categorical_features = load_epa_data(df)

#=================================================================
# 5. OneHotEncoder compatibility: Convert categorical features into
#    a oneHot mnumerical array
#=================================================================

def make_onehot_encoder():
    try:
        return OneHotEncoder(handle_unknown="ignore", sparse_output=False)
    except TypeError:
        return OneHotEncoder(handle_unknown="ignore", sparse=False)

#=================================================================
# 6. Build regression pipeline
#=================================================================

def build_regression_pipeline(
    numerical_features,
    categorical_features,
    degree=1,
    model_type="linear"
):
    if degree == 1:
        num_pipeline = Pipeline(steps=[
            ("imputer", SimpleImputer(strategy="median")),
            ("scaler", StandardScaler())
        ])
    else:
        num_pipeline = Pipeline(steps=[
            ("imputer", SimpleImputer(strategy="median")),
            ("scaler", StandardScaler()),
            ("poly", PolynomialFeatures(degree=degree, include_bias=False))
        ])

    cat_pipeline = Pipeline(steps=[
        ("imputer", SimpleImputer(strategy="constant", fill_value="missing")),
        ("onehot", make_onehot_encoder())
    ])

    transformers = []

    if numerical_features:
        transformers.append(("num", num_pipeline, numerical_features))

    if categorical_features:
        transformers.append(("cat", cat_pipeline, categorical_features))

    preprocessor = ColumnTransformer(
        transformers=transformers,
        remainder="drop"
    )

    if model_type == "dummy":
        model = DummyRegressor(strategy="mean")
    else:
        model = LinearRegression()

    pipeline = Pipeline(steps=[
        ("preprocessor", preprocessor),
        ("model", model)
    ])

    return pipeline

#=================================================================
# 7. Cross-validation evaluation
#=================================================================

def evaluate_cv(model, X, y, cv_splits=5):
    kf = KFold(n_splits=cv_splits, shuffle=True, random_state=42)

    scoring = {
        "mse": "neg_mean_squared_error",
        "mae": "neg_mean_absolute_error",
        "r2": "r2"
    }

    scores = cross_validate(
        model,
        X,
        y,
        cv=kf,
        scoring=scoring,
        return_train_score=False
    )

    mse_scores = -scores["test_mse"]
    mae_scores = -scores["test_mae"]
    r2_scores = scores["test_r2"]

    return {
        "MSE Mean": mse_scores.mean(),
        "MSE Std": mse_scores.std(),
        "R2 Mean": r2_scores.mean(),
        "R2 Std": r2_scores.std(),
        "MAE Mean": mae_scores.mean(),
        "MAE Std": mae_scores.std()
    }

#=================================================================
# 8. Compare baseline, linear, polynomial models
#=================================================================

def compare_models(X, y, numerical_features, categorical_features):
    results = []

    baseline = build_regression_pipeline(
        numerical_features,
        categorical_features,
        degree=1,
        model_type="dummy"
    )

    baseline_results = evaluate_cv(baseline, X, y)
    baseline_results["Model"] = "Mean baseline"
    baseline_results["Degree"] = 0
    results.append(baseline_results)

    for degree in [1, 2, 3, 4]:
        model = build_regression_pipeline(
            numerical_features,
            categorical_features,
            degree=degree,
            model_type="linear"
        )

        model_results = evaluate_cv(model, X, y)
        model_results["Degree"] = degree

        if degree == 1:
            model_results["Model"] = "Linear"
        else:
            model_results["Model"] = f"Polynomial d={degree}"

        results.append(model_results)

    results_df = pd.DataFrame(results)

    print("\nCross-Validated Model Results:")
    display(
        results_df[
            ["Model", "MSE Mean", "MSE Std", "R2 Mean", "R2 Std", "MAE Mean", "MAE Std"]
        ].round(3)
    )

    return results_df

# Call to compare baseline, linear, polynomial models
results_df = compare_models(
    X,
    y,
    numerical_features,
    categorical_features
)

